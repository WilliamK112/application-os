# PostgreSQL connection for Prisma
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/application_os?schema=public"

# Optional: switch repository provider (default: prisma)
# APP_OS_REPOSITORY_PROVIDER="mock"

# Local auth defaults (recommended to avoid NextAuth warnings in dev)
NEXTAUTH_URL="http://localhost:3000"
AUTH_SECRET="replace-with-a-long-random-secret"

# Optional: default bootstrap user for local single-user MVP
APP_OS_DEFAULT_USER_EMAIL="candidate@example.com"
APP_OS_DEFAULT_USER_NAME="Alex Candidate"
APP_OS_DEFAULT_USER_PASSWORD="candidate123"

# Auto-apply applicant profile (required for live external provider probe/submit)
# APP_OS_APPLICANT_FULL_NAME="Alex Candidate"
# APP_OS_APPLICANT_EMAIL="candidate@example.com"
# APP_OS_APPLICANT_PHONE="+1-555-000-1111"
# APP_OS_APPLICANT_RESUME_URL="https://example.com/resume.pdf"

# Password reset email adapter
# APP_OS_EMAIL_PROVIDER="console" # console | resend
# APP_OS_PUBLIC_URL="http://localhost:3000" # fallback to NEXTAUTH_URL when unset
# APP_OS_EMAIL_FROM="Application OS <no-reply@example.com>"
# APP_OS_RESEND_API_KEY="re_xxx"

# Reminders / notification email
# Email to receive follow-up and interview reminders
# APP_OS_NOTIFY_EMAIL="you@example.com"
# Secret token for /api/reminders endpoint (required for production cron)
# REMINDERS_SECRET="your-random-secret"

# S3 / R2 file storage (document uploads)
# Leave empty to use local-only mode (no actual upload)
# APP_OS_S3_ENDPOINT="https://abc123.r2.cloudflarestorage.com"
# APP_OS_S3_REGION="auto"
# APP_OS_S3_BUCKET="application-os-uploads"
# APP_OS_S3_ACCESS_KEY_ID="your-access-key"
# APP_OS_S3_SECRET_ACCESS_KEY="your-secret-key"
# APP_OS_S3_PUBLIC_URL_BASE="https://pub.yourdomain.com" # CDN base for public URLs
